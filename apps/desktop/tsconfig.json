{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "outDir": "./dist/renderer",
    "baseUrl": "./src/renderer",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["src/renderer"],
  "references": [{ "path": "./tsconfig.main.json" }]
}
